{
  "qcloud": {
    "apiUrl": "https://open.bigmodel.cn/api/anthropic",
    "apiKey": "your-api-key",
    "models": ["glm-5", "glm-5-turbo", "glm-4.7"]
  },
  "aliyun": {
    "apiUrl": "https://open.bigmodel.cn/api/anthropic",
    "apiKey": "your-api-key",
    "models": ["glm-5", "glm-5-turbo"]
  },
  "aws": {
    "env": {
      "CLAUDE_CODE_USE_BEDROCK": "1",
      "AWS_REGION": "ap-southeast-1",
      "AWS_BEARER_TOKEN_BEDROCK": "your-aws-bearer-token"
    },
    "models": ["anthropic.claude-opus-4-6-v1", "anthropic.claude-sonnet-4-6"]
  }
}
